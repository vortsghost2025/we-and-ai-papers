  border-radius: 4px;
  padding: 15px 20px;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20px;
}

.pillar-container {
  width: 30px;
  height: 80px;
  background: #1a1a2e;
  border-radius: 3px;
  position: relative;
  overflow: hidden;
}

.pillar-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(0deg, #4a8a4a 0%, #2a4a2a 100%);
