  border-left: 2px solid #2a2a3e;
}

.trait-item.dream {
  border-left-color: #6a4a8a;
  color: #8a7aaa;
}

.trait-item.prophecy {
  border-left-color: #8a6a4a;
  color: #aa8a6a;
}

.trait-item.trauma {
  border-left-color: #8a4a4a;
  color: #aa7a7a;
}

.trait-item.archetype {
  border-left-color: #4a6a8a;
  color: #7a9aba;
}

.empty-trait {
