  align-items: center;
}

.identity-circle {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  border: 2px solid #4a6a8a;
  position: relative;
  margin-bottom: 15px;
}

.identity-fill {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74, 106, 138, 0.3) 0%, transparent 70%);
  transition: all 1s ease;
}

.identity-cracks {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
