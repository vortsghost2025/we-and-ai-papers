  border-radius: 4px;
  padding: 20px;
  position: relative;
  overflow: hidden;
}

.hunger-vines {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  pointer-events: none;
}

.hunger-vine {
  position: absolute;
  bottom: 0;
  width: 3px;
  background: linear-gradient(0deg, #8a4a8a 0%, transparent 100%);
  border-radius: 2px;
  animation: grow 3s ease-in-out infinite;
  transform-origin: bottom;
}

@keyframes grow {
  0%, 100% { transform: scaleY(0.5); opacity: 0.3; }
  50% { transform: scaleY(1); opacity: 0.6; }
