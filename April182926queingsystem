Diff function (core of convergence queue):
function phenotypeDiff(a: Phenotype, b: Phenotype): DiffResult {
  const result: DiffResult = {
    compatible: false,
    reasons: [],
    score: 0,
    action: 'CONVERGE' as 'CONVERGE' | 'QUARANTINE_BOTH' | 'ABORT_RUN'
  };

  // 1. Structural (must match)
  if (a.paper_ref !== b.paper_ref) {
    result.reasons.push('paper_ref_mismatch');
    result.action = 'QUARANTINE_BOTH';
    return result;
  }

  // 2. Hash equality (exact code/impl match)
  if (a.code_impl_hash === b.code_impl_hash) {
    result.score += 0.4;
  } else {
    result.reasons.push('impl_hash_mismatch');
  }

  // 3. Lattice compliance (your global + individualized constraints)
  const latticeDelta = vectorDistance(a.lattice_vector, b.lattice_vector); // cosine or Euclidean, threshold < 0.05
  if (latticeDelta > 0.05) {
    result.reasons.push('lattice_inconsistency');
    if (a.drift_class === 'constitution' || b.drift_class === 'constitution') {
      result.action = 'ABORT_RUN'; // stop-the-line
    }
    return result;
  }
  result.score += 0.4;

  // 4. Constraint satisfaction threshold (your CPS_ENFORCEMENT)
  if (Math.min(a.constraint_satisfaction, b.constraint_satisfaction) < 0.95) {
    result.reasons.push('constraint_satisfaction_below_threshold');
    result.action = 'QUARANTINE_BOTH';
    return result;
  }
  result.score += 0.2;

  // 5. Drift class cross-check (your Decision Matrix)
  if (a.drift_class !== 'none' || b.drift_class !== 'none') {
    result.reasons.push(`drift_detected_\( {a.drift_class}_ \){b.drift_class}`);
    result.action = 'QUARANTINE_BOTH';
    return result;
  }

  result.compatible = result.score >= 0.95;
  if (result.compatible) result.action = 'CONVERGE';
  return result;
}
