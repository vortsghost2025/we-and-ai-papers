const probeEntry = {
  ts: Date.now(),
  pid: process.pid,
  itemId: queueItem?.id || 'unknown',
  lane: process.env.LANE_NAME || 'unidentified',
  stage: 'entry', // 'entry' | 'exit-success' | 'exit-failure' | 'shadow-reject'
