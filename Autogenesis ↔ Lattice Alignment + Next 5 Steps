  fs.appendFileSync(probeLog, JSON.stringify({
    ...probeEntry, 
    stage: 'exit-failure',
    evidence: 'verified' // If this line fires, verification actually ran
  }) + '\n');
} else if (result === 'ACCEPTED' || result === true) {
  fs.appendFileSync(probeLog, JSON.stringify({...probeEntry, stage: 'exit-success'}) + '\n');
}

// SHADOW DETECTION: If we reach end without logging exit, something is wrong
// (Add this block at the very end of the function before return)
process.nextTick(() => {
  // Check if exit was logged by reading last line (inefficient but provable)
  const lines = fs.readFileSync(probeLog, 'utf8').trim().split('\n');
  const lastLine = JSON.parse(lines[lines.length - 1]);
  if (lastLine.itemId === probeEntry.itemId && lastLine.stage === 'entry') {
    // Entry logged but no exit logged → Shadow path taken inside function
    fs.appendFileSync(probeLog, JSON.stringify({
      ...probeEntry,
      stage: 'shadow-reject',
      warning: 'Function entered but exited without logging - bypass detected'
    }) + '\n');
  }
});
```

